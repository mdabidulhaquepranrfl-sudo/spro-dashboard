# ==============================================================================
# SPRO Dashboard - Custom Next.js Git Ignore
# ==============================================================================

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js Build Output
.next/
out/
build/
dist/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment Variables & Secrets (CRITICAL SECURITY)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
*.cert
*.pfx

# IDE / Editor Files
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS / System Files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Testing & Coverage
coverage/
.nyc_output/
.playwright/
test-results/

# Temporary / Cache Files
.eslintcache
.stylelintcache
.sass-cache
.cache/
.parcel-cache/

# Agent/Antigravity Workspace Trash/Metadata
.agents/
.gemini/
